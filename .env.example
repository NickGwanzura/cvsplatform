# Upstream Laravel API. MUST be HTTPS in production. The browser never talks
# to this directly — the Hono proxy forwards /api/v1/* server-side.
UPSTREAM_API_URL=https://api.example.com/api/v1

# Comma-separated origins allowed to call the proxy. Defaults to APP_URL.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:5173

# Browser origin of the SPA. Used as a CORS fallback if ALLOWED_ORIGINS unset.
APP_URL=http://localhost:5173

# Drizzle Kit reads this for migrations. Never commit a real value.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Set to "true" only if the upstream presents a self-signed/invalid cert AND
# you accept the MITM risk on that hop. Default: validate certs.
# UPSTREAM_INSECURE_TLS=false

# Opt-in browser console logging for the API client. Off by default.
# NEXT_PUBLIC_API_DEBUG=true

# Optional override for the SPA's API base URL. Leave unset to use /api/v1.
# NEXT_PUBLIC_API_BASE_URL=/api/v1
